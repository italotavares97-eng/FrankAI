# =============================================================================
# .ENV.EXAMPLE — Frank AI OS · Davvero Gelato
# Copie para .env e preencha os valores antes de rodar o docker compose
# =============================================================================

# ---------------------------------------------------------------------------
# ANTHROPIC — OBRIGATÓRIO
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# BANCO DE DADOS
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=senha_forte_aqui
POSTGRES_URL=postgresql://frank:${POSTGRES_PASSWORD}@postgres:5432/davvero

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
REDIS_PASSWORD=redis_senha_aqui
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---------------------------------------------------------------------------
# RABBITMQ
# ---------------------------------------------------------------------------
RABBITMQ_PASSWORD=rabbit_senha_aqui
RABBITMQ_URL=amqp://frank:${RABBITMQ_PASSWORD}@rabbitmq:5672/davvero

# ---------------------------------------------------------------------------
# APLICAÇÃO
# ---------------------------------------------------------------------------
ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://frank.davverogelato.com.br

# ---------------------------------------------------------------------------
# EMAIL (SMTP)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=frank@davverogelato.com.br
SMTP_PASS=app_password_aqui
SMTP_FROM=frank@davverogelato.com.br

# ---------------------------------------------------------------------------
# WHATSAPP BUSINESS API
# ---------------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=davvero_frank_2026

# ---------------------------------------------------------------------------
# META ADS
# ---------------------------------------------------------------------------
META_ADS_TOKEN=
META_ADS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# LINKEDIN
# ---------------------------------------------------------------------------
LINKEDIN_TOKEN=
LINKEDIN_ORG_ID=

# ---------------------------------------------------------------------------
# ERP — SULTS / LINX
# ---------------------------------------------------------------------------
ERP_SULTS_URL=https://api.sults.com.br/v1
ERP_SULTS_TOKEN=
ERP_LINX_URL=
ERP_LINX_TOKEN=

# ---------------------------------------------------------------------------
# GOOGLE SHEETS / BI
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_CREDENTIALS=credentials.json
SHEETS_DRE_ID=
SHEETS_KPI_ID=

# ---------------------------------------------------------------------------
# PGADMIN (opcional, perfil tools)
# ---------------------------------------------------------------------------
PGADMIN_EMAIL=admin@davverogelato.com.br
PGADMIN_PASSWORD=pgadmin_senha
